{
  "manifest_version": 3,
  "name": "QA Tracker Extension",
  "version": "1.0",
  "description": "Press Ctrl+Q to open QA Tracker for tracking bugs locally.",
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": ["http://localhost/*", "http://127.0.0.1/*", "http://*/*", "https://*/*"],
      "js": ["content.js"],
      "all_frames": true
    }
  ],
  "host_permissions": [
    "*://script.google.com/*",
    "*://script.googleusercontent.com/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["index.html", "src/app.js", "style.css"],
      "matches": ["<all_urls>"]
    }
  ]
}
