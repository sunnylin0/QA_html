{
  "manifest_version": 3,
  "name": "QA Tracker Extension",
  "version": "1.1.0",
  "description": "Press Ctrl+Q to open QA Tracker for tracking bugs locally.",
  "icons": {
    "16": "icons/icon.png",
	"48": "icons/icon.png",
	"128": "icons/icon.png"
  },
  "permissions": [
    "storage"
  ],
  "content_scripts": [
    {
      "matches": [
        "http://localhost/*",
        "http://127.0.0.1/*",
        "http://192.168.2.134/*"
      ],
      "js": [
        "content.js"
      ],
      "all_frames": true
    }
  ],
  "host_permissions": [
    "*://script.google.com/*",
    "*://script.googleusercontent.com/*"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "index.html",
        "src/app.js",
        "style.css"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}